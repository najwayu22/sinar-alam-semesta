# Port server backend (Render.com akan inject PORT sendiri)
PORT=3000

# JSON Web Token Secret Key untuk keamanan sesi login
JWT_SECRET="your-secret-key-here"

# URL frontend yang diizinkan CORS
# Isi dengan URL Netlify kamu jika deploy terpisah
FRONTEND_URL="http://localhost:5173"

# Google Gemini API Key (opsional - untuk fitur AI)
GEMINI_API_KEY=""

# URL Backend API (untuk frontend)
# Kosongkan untuk development lokal
# Isi dengan URL Render.com saat deploy di Netlify
VITE_API_URL=""

JWT_SECRET=kunci-rahasia-jwt-sinar-alam-2026
FRONTEND_URL=https://pt-sinar-alam-semesta.netlify.app
NODE_ENV=production
